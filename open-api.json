{
    "openapi": "3.0.3",
    "info": {
      "title": "Hackathon API",
      "description": "API para gerenciamento de Voluntários, Instituições e Inscrições (Status: confirmed/cancelled).",
      "version": "1.4.0"
    },
    "servers": [
      {
        "url": "https://crisismatch-api.vercel.app/",
        "description": "Servidor Principal"
      }
    ],
    "tags": [
      { "name": "Volunteers", "description": "Gerenciamento de voluntários" },
      { "name": "Organizations", "description": "Gerenciamento de instituições" },
      { "name": "Actions", "description": "Vagas e ações de voluntariado" },
      { "name": "Enrollments", "description": "Inscrições (confirmed ou cancelled)" }
    ],
    "paths": {
      "/api/volunteers": {
        "get": {
          "tags": ["Volunteers"],
          "summary": "Buscar voluntário",
          "operationId": "getVolunteerByEmailOrId",
          "parameters": [
            { "name": "email", "in": "query", "schema": { "type": "string", "format": "email" } },
            { "name": "id", "in": "query", "schema": { "type": "string", "format": "uuid" } }
          ],
          "responses": {
            "200": { "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Volunteer" } } } },
            "404": { "$ref": "#/components/responses/NotFound" }
          }
        },
        "post": {
          "tags": ["Volunteers"],
          "summary": "Criar voluntário",
          "operationId": "createVolunteer",
          "requestBody": { "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateVolunteerInput" } } } },
          "responses": { "201": { "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Volunteer" } } } } }
        }
      },
      "/api/volunteers/{id}/enrollments": {
        "get": {
          "tags": ["Enrollments"],
          "summary": "Inscrições de um voluntário",
          "operationId": "getEnrollmentsByVolunteer",
          "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
          "responses": {
            "200": { "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Enrollment" } } } } }
          }
        }
      },
      "/api/organizations": {
        "post": {
          "tags": ["Organizations"],
          "summary": "Criar instituição",
          "operationId": "createOrganization",
          "requestBody": { "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateOrganizationInput" } } } },
          "responses": { "201": { "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Organization" } } } } }
        }
      },
      "/api/organizations/{organizationId}/actions": {
        "get": {
          "tags": ["Actions"],
          "summary": "Ações de uma organização",
          "parameters": [{ "name": "organizationId", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
          "responses": { "200": { "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Action" } } } } } }
        }
      },
      "/api/actions": {
        "get": {
          "tags": ["Actions"],
          "summary": "Listar ações disponíveis",
          "description": "Retorna ações futuras onde confirmed_enrollments < vacancies.",
          "operationId": "getAvailableActions",
          "responses": {
            "200": { "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Action" } } } } }
          }
        },
        "post": {
          "tags": ["Actions"],
          "summary": "Criar ação",
          "operationId": "createAction",
          "requestBody": { "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateActionInput" } } } },
          "responses": { "201": { "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Action" } } } } }
        }
      },
      "/api/actions/{id}": {
        "get": { "tags": ["Actions"], "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }], "responses": { "200": { "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Action" } } } } } },
        "patch": { "tags": ["Actions"], "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }], "requestBody": { "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UpdateActionInput" } } } }, "responses": { "200": { "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Action" } } } } } }
      },
      "/api/enrollments": {
        "post": {
          "tags": ["Enrollments"],
          "summary": "Nova inscrição",
          "description": "Cria uma inscrição com status 'confirmed' se houver vagas.",
          "operationId": "createEnrollment",
          "requestBody": { "content": { "application/json": { "schema": { "$ref": "#/components/schemas/CreateEnrollmentInput" } } } },
          "responses": {
            "201": { "description": "Inscrito com sucesso" },
            "400": { "description": "Sem vagas disponíveis" },
            "409": { "description": "Voluntário já inscrito nesta ação" }
          }
        }
      },
      "/api/enrollments/{id}": {
        "get": {
          "tags": ["Enrollments"],
          "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
          "responses": { "200": { "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Enrollment" } } } } }
        },
        "patch": {
          "tags": ["Enrollments"],
          "summary": "Cancelar inscrição",
          "description": "Altera o status da inscrição para 'cancelled'.",
          "operationId": "cancelEnrollment",
          "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "string", "format": "uuid" } }],
          "responses": { "200": { "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Enrollment" } } } } }
        }
      }
    },
    "components": {
      "schemas": {
        "Volunteer": {
          "type": "object",
          "properties": {
            "id": { "type": "string", "format": "uuid" },
            "name": { "type": "string" },
            "email": { "type": "string" },
            "skills": { "type": "array", "items": { "type": "string" } },
            "interests": { "type": "array", "items": { "type": "string" } },
            "availability": { "type": "string" }
          }
        },
        "Organization": {
          "type": "object",
          "properties": {
            "id": { "type": "string", "format": "uuid" },
            "name": { "type": "string" },
            "email": { "type": "string" },
            "description": { "type": "string" }
          }
        },
        "Action": {
          "type": "object",
          "properties": {
            "id": { "type": "string", "format": "uuid" },
            "title": { "type": "string" },
            "description": { "type": "string" },
            "organization_id": { "type": "string", "format": "uuid" },
            "location": { "type": "string" },
            "date": { "type": "string", "format": "date-time" },
            "required_skills": { "type": "array", "items": { "type": "string" } },
            "interests": { "type": "array", "items": { "type": "string" } },
            "vacancies": { "type": "integer" }
          }
        },
        "Enrollment": {
          "type": "object",
          "properties": {
            "id": { "type": "string", "format": "uuid" },
            "volunteer_id": { "type": "string", "format": "uuid" },
            "action_id": { "type": "string", "format": "uuid" },
            "status": { "type": "string", "enum": ["confirmed", "cancelled"] },
            "created_at": { "type": "string", "format": "date-time" }
          }
        },
        "CreateVolunteerInput": { "type": "object", "required": ["name", "email"], "properties": { "name": { "type": "string" }, "email": { "type": "string" }, "skills": { "type": "array", "items": { "type": "string" } }, "interests": { "type": "array", "items": { "type": "string" } }, "availability": { "type": "string" } } },
        "CreateOrganizationInput": { "type": "object", "required": ["name", "email", "description"], "properties": { "name": { "type": "string" }, "email": { "type": "string" }, "description": { "type": "string" } } },
        "CreateActionInput": { "type": "object", "required": ["title", "organization_id", "date", "vacancies"], "properties": { "title": { "type": "string" }, "description": { "type": "string" }, "organization_id": { "type": "string" }, "location": { "type": "string" }, "date": { "type": "string" }, "vacancies": { "type": "integer" } } },
        "UpdateActionInput": { "type": "object", "properties": { "title": { "type": "string" }, "description": { "type": "string" }, "vacancies": { "type": "integer" } } },
        "CreateEnrollmentInput": { "type": "object", "required": ["volunteer_id", "action_id"], "properties": { "volunteer_id": { "type": "string", "format": "uuid" }, "action_id": { "type": "string", "format": "uuid" } } },
        "Error": { "type": "object", "properties": { "error": { "type": "string" } } }
      },
      "responses": {
        "NotFound": { "description": "Recurso não encontrado", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } },
        "InternalError": { "description": "Erro interno", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } } }
      }
    }
  }