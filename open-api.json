{
    "openapi": "3.0.3",
    "info": {
      "title": "Hackathon API",
      "description": "API para gerenciamento de Voluntários, Instituições e Ações de voluntariado no Hackathon.",
      "version": "1.2.0"
    },
    "servers": [
      {
        "url": "https://crisismatch-api.vercel.app/",
        "description": "Produção/Vercel"
      }
    ],
    "tags": [
      {
        "name": "Volunteers",
        "description": "Operações relacionadas a voluntários"
      },
      {
        "name": "Organizations",
        "description": "Operações relacionadas a instituições"
      },
      {
        "name": "Actions",
        "description": "Operações relacionadas a ações e vagas de voluntariado"
      }
    ],
    "paths": {
      "/api/volunteers": {
        "get": {
          "tags": ["Volunteers"],
          "summary": "Buscar voluntário por e-mail ou ID",
          "operationId": "getVolunteerByEmailOrId",
          "parameters": [
            {
              "name": "email",
              "in": "query",
              "required": false,
              "schema": { "type": "string", "format": "email" }
            },
            {
              "name": "id",
              "in": "query",
              "required": false,
              "schema": { "type": "string", "format": "uuid" }
            }
          ],
          "responses": {
            "200": {
              "description": "Voluntário encontrado",
              "content": {
                "application/json": {
                  "schema": { "$ref": "#/components/schemas/Volunteer" }
                }
              }
            },
            "400": { "$ref": "#/components/responses/MissingQueryParam" },
            "404": { "$ref": "#/components/responses/NotFound" },
            "500": { "$ref": "#/components/responses/InternalError" }
          }
        },
        "post": {
          "tags": ["Volunteers"],
          "summary": "Criar voluntário",
          "operationId": "createVolunteer",
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CreateVolunteerInput" }
              }
            }
          },
          "responses": {
            "201": {
              "description": "Voluntário criado",
              "content": {
                "application/json": {
                  "schema": { "$ref": "#/components/schemas/Volunteer" }
                }
              }
            },
            "409": { "$ref": "#/components/responses/Conflict" },
            "422": { "$ref": "#/components/responses/UnprocessableEntity" },
            "500": { "$ref": "#/components/responses/InternalError" }
          }
        },
        "patch": {
          "tags": ["Volunteers"],
          "summary": "Atualizar voluntário",
          "operationId": "updateVolunteer",
          "parameters": [
            {
              "name": "id",
              "in": "query",
              "required": true,
              "schema": { "type": "string", "format": "uuid" }
            }
          ],
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UpdateVolunteerInput" }
              }
            }
          },
          "responses": {
            "200": {
              "description": "Voluntário atualizado",
              "content": {
                "application/json": {
                  "schema": { "$ref": "#/components/schemas/Volunteer" }
                }
              }
            },
            "400": { "$ref": "#/components/responses/MissingQueryParam" },
            "404": { "$ref": "#/components/responses/NotFound" },
            "500": { "$ref": "#/components/responses/InternalError" }
          }
        }
      },
      "/api/organizations": {
        "get": {
          "tags": ["Organizations"],
          "summary": "Buscar instituição por e-mail ou ID",
          "operationId": "getOrganizationByEmailOrId",
          "parameters": [
            {
              "name": "email",
              "in": "query",
              "required": false,
              "schema": { "type": "string", "format": "email" }
            },
            {
              "name": "id",
              "in": "query",
              "required": false,
              "schema": { "type": "string", "format": "uuid" }
            }
          ],
          "responses": {
            "200": {
              "description": "Instituição encontrada",
              "content": {
                "application/json": {
                  "schema": { "$ref": "#/components/schemas/Organization" }
                }
              }
            },
            "400": { "$ref": "#/components/responses/MissingQueryParam" },
            "404": { "$ref": "#/components/responses/NotFound" },
            "500": { "$ref": "#/components/responses/InternalError" }
          }
        },
        "post": {
          "tags": ["Organizations"],
          "summary": "Criar instituição",
          "operationId": "createOrganization",
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CreateOrganizationInput" }
              }
            }
          },
          "responses": {
            "201": {
              "description": "Instituição criada",
              "content": {
                "application/json": {
                  "schema": { "$ref": "#/components/schemas/Organization" }
                }
              }
            },
            "409": { "$ref": "#/components/responses/Conflict" },
            "500": { "$ref": "#/components/responses/InternalError" }
          }
        }
      },
      "/api/actions": {
        "get": {
          "tags": ["Actions"],
          "summary": "Obter ações disponíveis",
          "description": "Retorna uma lista de ações que possuem vagas (vacancies > 0) e data de realização futura.",
          "operationId": "getAvailableActions",
          "responses": {
            "200": {
              "description": "Lista de ações disponíveis",
              "content": {
                "application/json": {
                  "schema": {
                    "type": "array",
                    "items": { "$ref": "#/components/schemas/Action" }
                  }
                }
              }
            },
            "500": { "$ref": "#/components/responses/InternalError" }
          }
        },
        "post": {
          "tags": ["Actions"],
          "summary": "Criar nova ação",
          "operationId": "createAction",
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/CreateActionInput" }
              }
            }
          },
          "responses": {
            "201": {
              "description": "Ação criada",
              "content": {
                "application/json": {
                  "schema": { "$ref": "#/components/schemas/Action" }
                }
              }
            },
            "400": { "description": "Campos obrigatórios ausentes" },
            "500": { "$ref": "#/components/responses/InternalError" }
          }
        }
      },
      "/api/actions/{id}": {
        "get": {
          "tags": ["Actions"],
          "summary": "Obter ação por ID",
          "operationId": "getActionById",
          "parameters": [
            {
              "name": "id",
              "in": "path",
              "required": true,
              "schema": { "type": "string", "format": "uuid" }
            }
          ],
          "responses": {
            "200": {
              "description": "Ação encontrada",
              "content": {
                "application/json": {
                  "schema": { "$ref": "#/components/schemas/Action" }
                }
              }
            },
            "404": { "$ref": "#/components/responses/NotFound" },
            "500": { "$ref": "#/components/responses/InternalError" }
          }
        },
        "patch": {
          "tags": ["Actions"],
          "summary": "Atualizar ação",
          "operationId": "updateAction",
          "parameters": [
            {
              "name": "id",
              "in": "path",
              "required": true,
              "schema": { "type": "string", "format": "uuid" }
            }
          ],
          "requestBody": {
            "required": true,
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/UpdateActionInput" }
              }
            }
          },
          "responses": {
            "200": {
              "description": "Ação atualizada",
              "content": {
                "application/json": {
                  "schema": { "$ref": "#/components/schemas/Action" }
                }
              }
            },
            "400": { "description": "Nenhum campo válido fornecido" },
            "404": { "$ref": "#/components/responses/NotFound" },
            "500": { "$ref": "#/components/responses/InternalError" }
          }
        }
      },
      "/api/organizations/{organizationId}/actions": {
        "get": {
          "tags": ["Actions"],
          "summary": "Listar ações de uma organização específica",
          "operationId": "getActionsByOrganization",
          "parameters": [
            {
              "name": "organizationId",
              "in": "path",
              "required": true,
              "schema": { "type": "string", "format": "uuid" }
            }
          ],
          "responses": {
            "200": {
              "description": "Lista de ações da organização",
              "content": {
                "application/json": {
                  "schema": {
                    "type": "array",
                    "items": { "$ref": "#/components/schemas/Action" }
                  }
                }
              }
            },
            "400": { "description": "organizationId é obrigatório" },
            "500": { "$ref": "#/components/responses/InternalError" }
          }
        }
      }
    },
    "components": {
      "schemas": {
        "Volunteer": {
          "type": "object",
          "properties": {
            "id": { "type": "string", "format": "uuid" },
            "name": { "type": "string" },
            "email": { "type": "string", "format": "email" },
            "skills": { "type": "array", "items": { "type": "string" } },
            "interests": { "type": "array", "items": { "type": "string" } },
            "availability": { "type": "string" },
            "created_at": { "type": "string", "format": "date-time" }
          }
        },
        "Organization": {
          "type": "object",
          "properties": {
            "id": { "type": "string", "format": "uuid" },
            "name": { "type": "string" },
            "email": { "type": "string", "format": "email" },
            "description": { "type": "string" },
            "created_at": { "type": "string", "format": "date-time" }
          }
        },
        "Action": {
          "type": "object",
          "properties": {
            "id": { "type": "string", "format": "uuid" },
            "title": { "type": "string" },
            "description": { "type": "string" },
            "organization_id": { "type": "string", "format": "uuid" },
            "location": { "type": "string" },
            "date": { "type": "string", "format": "date-time" },
            "required_skills": { "type": "array", "items": { "type": "string" } },
            "interests": { "type": "array", "items": { "type": "string" } },
            "vacancies": { "type": "integer" },
            "created_at": { "type": "string", "format": "date-time" }
          }
        },
        "CreateVolunteerInput": {
          "type": "object",
          "required": ["name", "email", "skills", "interests", "availability"],
          "properties": {
            "name": { "type": "string" },
            "email": { "type": "string", "format": "email" },
            "skills": { "type": "array", "items": { "type": "string" } },
            "interests": { "type": "array", "items": { "type": "string" } },
            "availability": { "type": "string" }
          }
        },
        "UpdateVolunteerInput": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "email": { "type": "string", "format": "email" },
            "skills": { "type": "array", "items": { "type": "string" } },
            "interests": { "type": "array", "items": { "type": "string" } },
            "availability": { "type": "string" }
          }
        },
        "CreateOrganizationInput": {
          "type": "object",
          "required": ["name", "email", "description"],
          "properties": {
            "name": { "type": "string" },
            "email": { "type": "string", "format": "email" },
            "description": { "type": "string" }
          }
        },
        "CreateActionInput": {
          "type": "object",
          "required": ["title", "description", "organization_id", "location", "date", "vacancies"],
          "properties": {
            "title": { "type": "string" },
            "description": { "type": "string" },
            "organization_id": { "type": "string", "format": "uuid" },
            "location": { "type": "string" },
            "date": { "type": "string", "format": "date-time" },
            "required_skills": { "type": "array", "items": { "type": "string" } },
            "interests": { "type": "array", "items": { "type": "string" } },
            "vacancies": { "type": "integer" }
          }
        },
        "UpdateActionInput": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "description": { "type": "string" },
            "location": { "type": "string" },
            "date": { "type": "string", "format": "date-time" },
            "required_skills": { "type": "array", "items": { "type": "string" } },
            "interests": { "type": "array", "items": { "type": "string" } },
            "vacancies": { "type": "integer" }
          }
        },
        "Error": {
          "type": "object",
          "properties": {
            "error": { "type": "string" }
          }
        }
      },
      "responses": {
        "MissingQueryParam": {
          "description": "Parâmetros obrigatórios ausentes",
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
        },
        "NotFound": {
          "description": "Recurso não encontrado",
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
        },
        "Conflict": {
          "description": "Conflito (ex: email já cadastrado)",
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
        },
        "InternalError": {
          "description": "Erro interno no servidor",
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
        },
        "UnprocessableEntity": {
          "description": "Entidade improcessável / Erro de validação",
          "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Error" } } }
        }
      }
    }
  }